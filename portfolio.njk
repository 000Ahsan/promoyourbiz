            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="fit-img mx-3 radius-15">
      <img src="/assets/imgs/promoyourbiz-portfolio-banner.jpg" alt="" />
    </div>
  </header>

  <div class="works-mp section-padding pt-0 mt-50">
    <div class="container">
      <div class="row md-marg gallery">
        {% for item in portfolio %}
        <div class="col-lg-4 items">
          <div class="item">
            <div class="cont d-flex gap-5 align-items-center">
              <div>
                <h5>{{ item.title }}</h5>
                <p>{{ item.description }}</p>
              </div>
              <div class="ml-auto">
                <a href="{{ item.link }}">
                  <i class="fa-solid fa-chevron-right"></i>
                </a>
              </div>
            </div>
            <div class="img">
              <img src="{{ item.image }}" alt="" />
            </div>
            <div class="flex items-center gap-2 mt-3">
              {% for tag in item.tags %}
              <span class="text-sm rounded-full px-3 py-1 bg-main text-dark">{{ tag }}</span>
              {% endfor %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% include 'testimonials.njk' %}
</main>
