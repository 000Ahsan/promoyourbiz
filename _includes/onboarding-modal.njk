<div id="onboarding-modal-overlay" class="onboarding-modal-overlay" style="display:none;">
  <div class="onboarding-modal">
    <div class="modal-header">
      <div class="progress-bar">
        <div id="modal-progress-fill" class="progress-fill" style="width: 20%;"></div>
      </div>
      <button class="close-btn" id="modal-close-btn">
        <img src="/common/imgs/icons/times-solid.svg" alt="Close" />
      </button>
    </div>

    <div class="modal-content">
      <!-- Step 1: Service Selection -->
      <div class="step-content" id="modal-step-1">
        <div class="step-header">
          <h2>What can we help you with?</h2>
          <p>Choose the service that best fits your needs</p>
        </div>
        <div class="services-grid">
          <div class="service-card" data-service="branding">
            <div class="service-icon">🎨</div>
            <h4 class="service-name">Brand Strategy</h4>
          </div>
          <div class="service-card" data-service="website">
            <div class="service-icon">💻</div>
            <h4 class="service-name">Web Design / Development</h4>
          </div>
          <div class="service-card" data-service="marketing">
            <div class="service-icon">📈</div>
            <h4 class="service-name">Growth Partnership & SEO</h4>
          </div>
          <div class="service-card" data-service="content">
            <div class="service-icon">💡</div>
            <h4 class="service-name">Copywriting & Messaging</h4>
          </div>
        </div>
        <div class="step-actions">
          <button class="next-btn" id="step1-next" disabled>
            Continue
            <img src="/common/imgs/icons/arrow-top-right.svg" alt="" />
          </button>
        </div>
      </div>

      <!-- Step 2: Business Info -->
      <div class="step-content" id="modal-step-2" style="display:none;">
        <div class="step-header">
          <h2>Tell us about your business</h2>
          <p>This helps us understand your needs better</p>
        </div>
        <div class="form-group">
          <label>Business Name</label>
          <input type="text" id="modal-businessName" placeholder="Enter your business name" />
        </div>
        <div class="form-group">
          <label>Business Type</label>
          <select id="modal-businessType">
            <option value="">Select business type</option>
            <option value="Startup">Startup</option>
            <option value="Small Business">Small Business</option>
            <option value="Medium Business">Medium Business</option>
            <option value="Enterprise">Enterprise</option>
            <option value="Non-Profit">Non-Profit</option>
            <option value="Agency">Agency</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="step-actions">
          <button class="back-btn" data-goto="1">
            <img src="/common/imgs/icons/angle-left-solid.svg" alt="" />
            Back
          </button>
          <button class="next-btn" id="step2-next" disabled>
            Continue
            <img src="/common/imgs/icons/arrow-top-right.svg" alt="" />
          </button>
        </div>
      </div>

      <!-- Step 3: Project Details -->
      <div class="step-content" id="modal-step-3" style="display:none;">
        <div class="step-header">
          <h2>Project Details</h2>
          <p>Help us understand your project scope</p>
        </div>
        <div class="form-group">
          <label>Budget Range</label>
          <div class="radio-group">
            <label class="radio-option d-flex">
              <input type="radio" name="budget" value="under-5k" />
              <span class="radio-custom"></span>
              <span>Under $5,000</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="budget" value="5k-10k" />
              <span class="radio-custom"></span>
              <span>$5,000 - $10,000</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="budget" value="10k-25k" />
              <span class="radio-custom"></span>
              <span>$10,000 - $25,000</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="budget" value="25k-50k" />
              <span class="radio-custom"></span>
              <span>$25,000 - $50,000</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="budget" value="50k+" />
              <span class="radio-custom"></span>
              <span>$50,000+</span>
            </label>
          </div>
        </div>
        <div class="form-group">
          <label>Timeline</label>
          <div class="radio-group">
            <label class="radio-option d-flex">
              <input type="radio" name="timeline" value="asap" />
              <span class="radio-custom"></span>
              <span>ASAP</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="timeline" value="1-2-weeks" />
              <span class="radio-custom"></span>
              <span>1-2 weeks</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="timeline" value="1-month" />
              <span class="radio-custom"></span>
              <span>1 month</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="timeline" value="2-3-months" />
              <span class="radio-custom"></span>
              <span>2-3 months</span>
            </label>
            <label class="radio-option d-flex">
              <input type="radio" name="timeline" value="3+months" />
              <span class="radio-custom"></span>
              <span>3+ months</span>
            </label>
          </div>
        </div>
        <div class="form-group">
          <label>Project Description</label>
          <textarea id="modal-description" placeholder="Tell us about your project goals, requirements, and any specific needs..." rows="2"></textarea>
        </div>
        <div class="step-actions">
          <button class="back-btn" data-goto="2">
            <img src="/common/imgs/icons/angle-left-solid.svg" alt="" />
            Back
          </button>
          <button class="next-btn" id="step3-next" disabled>
            Continue
            <img src="/common/imgs/icons/arrow-top-right.svg" alt="" />
          </button>
        </div>
      </div>

      <!-- Step 4: Contact Info -->
      <div class="step-content" id="modal-step-4" style="display:none;">
        <div class="step-header">
          <h2>Contact Information</h2>
          <p>Lets get in touch to discuss your project</p>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" id="modal-contactName" placeholder="Enter your full name" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" id="modal-contactEmail" placeholder="Enter your email" />
          </div>
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" id="modal-contactPhone" placeholder="Enter your phone number" />
        </div>
        <div class="step-actions">
          <button class="back-btn" data-goto="3">
            <img src="/common/imgs/icons/angle-left-solid.svg" alt="" />
            Back
          </button>
          <button class="next-btn" id="step4-next" disabled>
            Continue
            <img src="/common/imgs/icons/arrow-top-right.svg" alt="" />
          </button>
        </div>
      </div>

      <!-- Step 5: Summary & Schedule -->
      <div class="step-content" id="modal-step-5" style="display:none;">
        <div class="step-header">
          <h2>Schedule a Call</h2>
          <p>Lets discuss your project in detail</p>
        </div>
        <div class="summary-card">
          <h3>Project Summary</h3>
          <div class="summary-item">
            <strong>Service:</strong> <span id="summary-service"></span>
          </div>
          <div class="summary-item">
            <strong>Business:</strong> <span id="summary-business"></span>
          </div>
          <div class="summary-item">
            <strong>Budget:</strong> <span id="summary-budget"></span>
          </div>
          <div class="summary-item">
            <strong>Timeline:</strong> <span id="summary-timeline"></span>
          </div>
        </div>
        <div class="contact-options">
          <div class="contact-option">
            <div class="option-icon">📞</div>
            <h4>Schedule a Call</h4>
            <p>Book a 30-minute consultation call to discuss your project</p>
            <a href="https://calendly.com/your-calendar" target="_blank" class="schedule-btn">
              Book Now
            </a>
          </div>
          <div class="contact-option">
            <div class="option-icon">📧</div>
            <h4>Send Email</h4>
            <p>We will review your information and get back to you within 24 hours</p>
            <button class="email-btn" id="modal-submit-btn">
              Submit Information
            </button>
          </div>
        </div>
        <div class="step-actions">
          <button class="back-btn" data-goto="4">
            <img src="/common/imgs/icons/angle-left-solid.svg" alt="" />
            Back
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
